# Set to False in production!
DEBUG=False
SECRET_KEY=your-secret-key-goes-here
# e.g., your-backend.onrender.com
ALLOWED_HOSTS=*
# Set this to False in production and specify CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL_ORIGINS=False
# Comma-separated list of allowed origins, e.g., https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# Render automatically injects DATABASE_URL
# DATABASE_URL=postgres://user:password@hostname:port/dbname
